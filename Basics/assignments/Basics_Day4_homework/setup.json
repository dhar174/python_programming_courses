{
  "file_checks": [
    "../Basics_Day4_homework.ipynb"
  ],
  "commands": [
    "python -m pip install --quiet --upgrade pip",
    "python -m pip install nbconvert",
    "jupyter nbconvert --to script ../Basics_Day4_homework.ipynb --output day4 --output-dir .",
    "if [ ! -f day4.py ]; then echo 'ERROR: Notebook conversion failed \u2014 day4.py not found'; exit 1; fi"
  ]
}
